# LOLANG AI Agent System - Environment Variables
# Copy this file to .env and fill in your values

# Gemini AI Configuration
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.8
GEMINI_MAX_TOKENS=8000
GEMINI_MESSAGE_DELAY=5
GEMINI_MAX_RETRIES=10
GEMINI_BASE_RETRY_DELAY=5

# Server Configuration
LOLANG_SERVER_HOST=localhost
LOLANG_SERVER_PORT=8765
LOLANG_MAX_CLIENTS=100
LOLANG_PING_INTERVAL=20
LOLANG_PING_TIMEOUT=10

# Client Configuration
LOLANG_SERVER_URI=ws://localhost:8765
LOLANG_MAX_CONVERSATIONS=20
LOLANG_AUTO_RECONNECT=true
LOLANG_RECONNECT_DELAY=5.0
LOLANG_MAX_RECONNECT_ATTEMPTS=5
